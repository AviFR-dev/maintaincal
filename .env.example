# Copy to .env and change secrets for production.

# Public hostname you will use in the browser (recommended).
MAINTAINCAL_HOST=maintaincal.lan

# API
API_PORT=8080
ORIGIN=https://${MAINTAINCAL_HOST}

# Auth/session (must be >= 32 chars)
SESSION_SECRET=change-me-please-change-me-please-32!

# Bootstrap admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin1234

# Web config (web container uses this at build/run time)
VITE_API_BASE=/api

